Screen {
    layout: vertical;
}

Throbber {
    width: 100%;
    height: 1;
    dock: top;
    visibility: hidden;
    &.-busy {
        visibility: visible;
    }
}

#conversation-scroll {
    height: 1fr;
    scrollbar-gutter: stable;
}

#conversation-content {
    height: auto;
    padding: 0 1;
}

/* User input blocks */
UserInput {
    margin: 1 0 0 0;
    height: auto;
    #prompt-icon {
        width: 2;
        color: $accent;
    }
    #content {
        width: 1fr;
    }
}

/* Agent response */
AgentResponse {
    margin: 1 0 0 1;
    height: auto;
}

/* Agent thought */
AgentThought {
    background: $primary-muted 20%;
    margin: 1 0 0 1;
    padding: 0 1;
    max-height: 10;
    overflow-y: auto;
    scrollbar-visibility: hidden;
    &.-loading {
        background: transparent;
        padding: 0;
        margin: 0;
    }
}

/* Tool calls */
ToolCall {
    margin: 0 0 0 1;
    height: auto;

    ToolCallHeader {
        color: $text-muted;
        &:hover {
            background: $panel;
        }
    }

    #tool-content {
        display: none;
        margin: 0 0 0 2;
        color: $text-muted;
    }

    &.-expanded #tool-content {
        display: block;
    }
}

/* Prompt bar at bottom */
Prompt {
    dock: bottom;
    height: auto;
    max-height: 8;
    padding: 0 1;
    background: $surface;

    #prompt-label {
        width: 2;
        color: $accent;
        padding: 1 0 0 0;
    }

    PromptInput {
        width: 1fr;
        min-height: 1;
        max-height: 6;
        border: tall transparent;
        &:focus {
            border: tall $primary;
        }
    }
}
