Screen {
    layout: vertical;
}

Throbber {
    width: 100%;
    height: 1;
    dock: top;
    visibility: hidden;
    &.-busy {
        visibility: visible;
    }
}

#conversation-scroll {
    height: 1fr;
    scrollbar-gutter: stable;
    overflow-y: auto;
}

#conversation-content {
    height: auto;
    padding: 0 1;
}

/* User input blocks */
UserInput {
    margin: 1 0 0 0;
    height: auto;
    #prompt-icon {
        width: 2;
        color: $accent;
    }
    #content {
        width: 1fr;
    }
}

/* Agent response */
AgentResponse {
    margin: 1 0 0 1;
    height: auto;
}

/* Error messages */
.error-msg {
    margin: 1 0 0 1;
    color: $error;
}

.help-msg {
    margin: 1 0 0 1;
}

/* Agent thought */
AgentThought {
    margin: 0 0 0 1;
    height: auto;
    max-height: 15;
    overflow-y: hidden;

    Collapsible {
        border-left: tall #555555;
        padding: 0 0 0 1;
    }

    CollapsibleTitle {
        color: $text-muted;
        text-style: italic;
        padding: 0;
    }

    Static {
        color: $text-muted;
        text-style: italic;
    }
}

/* Tool calls */
ToolCall {
    margin: 0 0 0 1;
    height: auto;

    ToolCallHeader {
        color: $text-muted;
        &:hover {
            background: $panel;
        }
    }

    #tool-content {
        display: none;
        margin: 0 0 0 2;
        color: $text-muted;
    }

    &.-expanded #tool-content {
        display: block;
    }
}

/* Welcome */
#welcome {
    content-align: center middle;
    text-align: center;
    color: $text-muted;
    width: 100%;
    margin: 2 0;
}

/* Session bar */
#session-bar {
    dock: bottom;
    width: 100%;
    height: 1;
    text-align: right;
    color: $text-muted;
    padding: 0 2;
    text-style: dim;
}

/* Prompt bar at bottom */
Prompt {
    dock: bottom;
    height: auto;
    max-height: 8;
    padding: 0 1;
    background: $surface;

    #prompt-label {
        width: 2;
        color: $accent;
        padding: 1 0 0 0;
    }

    PromptInput {
        width: 1fr;
        min-height: 1;
        max-height: 6;
        border: tall transparent;
        &:focus {
            border: tall $primary;
        }
    }
}
